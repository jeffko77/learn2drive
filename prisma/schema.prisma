generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id          String      @id
  name        String
  birthDate   DateTime    @map("birth_date")
  startDate   DateTime    @map("start_date")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  phases      Phase[]
  drivingLogs DrivingLog[]
  quizResults QuizResult[]

  @@map("drivers")
}

model Phase {
  id          String   @id
  driverId    String   @map("driver_id")
  orderIndex  Int      @map("order_index")
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  skills      Skill[]

  @@map("phases")
}

model Skill {
  id          String   @id
  phaseId     String   @map("phase_id")
  orderIndex  Int      @map("order_index")
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  teachingNotes String? @map("teaching_notes")

  phase       Phase    @relation(fields: [phaseId], references: [id])
  progress    SkillProgress?

  @@map("tasks")
}

model SkillProgress {
  id            String    @id
  skillId       String    @unique @map("task_id")
  status        String    @default("not_started")
  completedAt   DateTime? @map("completion_date")
  notes         String?
  feedback      String?
  updatedAt     DateTime  @updatedAt @map("updated_at")

  skill         Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@map("progress")
}

model DrivingLog {
  id        String   @id
  driverId  String   @map("driver_id")
  date      DateTime @db.Date
  duration  Int
  notes     String?
  roadTypes String?  @map("road_types")
  weather   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driving_logs")
}

model QuizQuestion {
  id            String   @id
  topic         String
  questionText  String   @map("question_text")
  optionA       String   @map("option_a")
  optionB       String   @map("option_b")
  optionC       String   @map("option_c")
  optionD       String   @map("option_d")
  correctAnswer String   @map("correct_answer")
  explanation   String?
  chapterReference String? @map("chapter_reference")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("quiz_questions")
}

model QuizResult {
  id         String   @id
  driverId   String   @map("driver_id")
  score      Int
  total      Int      @map("total_questions")
  topic      String?  @map("mode")
  createdAt  DateTime @default(now()) @map("date_taken")
  timeTaken  Int?     @map("time_taken")

  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}
